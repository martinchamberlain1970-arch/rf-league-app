{
  "name": "rack-and-frame-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "reset-and-run": "sh -c 'pkill -9 -f \"next dev|next start|next build|node.*next\" || true; rm -rf .next; npm run build -- --webpack; npm run start -- --hostname 127.0.0.1 --port 3000'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "next": "16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
